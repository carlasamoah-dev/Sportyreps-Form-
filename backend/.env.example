# ─────────────────────────────────────────────────
# Sportyreps Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git (it's already in .gitignore).
# ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Supabase (get from: https://app.supabase.com → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...

# Resend (get from: https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address that will receive new submission notifications
ADMIN_EMAIL=your@email.com

# The URL where your admin panel is hosted (used for links in emails)
ADMIN_DASHBOARD_URL=https://your-admin-dashboard-url.vercel.app
